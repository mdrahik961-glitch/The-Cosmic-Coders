    backgroundImage: `url(${spaceBg})`,
    backgroundSize: "cover",
    backgroundPosition: "center",
    backgroundRepeat: "no-repeat",
    zIndex: 0,
  },
  bgOverlay: {
    position: "fixed",
    inset: 0,
    background:
      "linear-gradient(to bottom, rgba(2,6,23,0.18), rgba(2,6,23,0.34), rgba(0,0,0,0.55))",
